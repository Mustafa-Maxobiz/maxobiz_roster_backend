# ===================== SECURITY =====================
SECRET_KEY=your_django_secret_key_here
DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# ===================== DATABASE =====================
# Use full URL format for dj_database_url
DATABASE_URL=postgres://db_user:db_password@localhost:5432/db_name
# Example: postgresql://myuser:mypassword@localhost:5432/mydb

# ===================== CORS =====================
CORS_ALLOW_CREDENTIALS=True
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ===================== EMAIL =====================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_email_password
DEFAULT_FROM_EMAIL=MyProject <your_email@gmail.com>

# ===================== SOCIAL LOGIN =====================
GOOGLE_CLIENT_ID=your_google_client_id
APPLE_CLIENT_ID=your_apple_service_id_or_bundle_id
APPLE_ISSUER=https://appleid.apple.com

# ===================== CELERY =====================
CELERY_BROKER_URL=amqp://guest:guest@localhost:5672//

# ===================== BRUTE FORCE / AXES =====================
AXES_ENABLED=True
AXES_FAILURE_LIMIT=5
AXES_COOLOFF_TIME=1
AXES_LOCK_OUT_AT_FAILURE=True
AXES_RESET_ON_SUCCESS=True
BRUTE_FORCE_DELAY_THRESHOLD=3
BRUTE_FORCE_DELAY_MIN_SECONDS=1.0
BRUTE_FORCE_DELAY_MAX_SECONDS=2.0
BRUTE_FORCE_DELAY_WINDOW_SECONDS=3600
BRUTE_FORCE_LOCKOUT_NOTIFY_THRESHOLD=2
BRUTE_FORCE_LOCKOUT_NOTIFY_WINDOW_SECONDS=86400
